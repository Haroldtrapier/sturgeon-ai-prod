# ==========================================
# STURGEON AI - ENVIRONMENT VARIABLES
# ==========================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.local
# 2. Fill in your real API keys
# 3. NEVER commit .env.local to Git
#
# ==========================================

# ------------------------------------------
# DEMO MODE (Set to 'true' for development)
# ------------------------------------------
# When enabled, uses mock responses instead of real API calls
# This prevents accidental charges during development
NEXT_PUBLIC_DEMO_MODE=true

# ------------------------------------------
# AI PROVIDERS (Required for Production)
# ------------------------------------------
# OpenAI (for GPT-4 Turbo)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (for Claude 3.5 Sonnet)
# Get your API key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ------------------------------------------
# COST OPTIMIZATION NOTES
# ------------------------------------------
# Claude 3.5 Sonnet: $3 per 1M input tokens, $15 per 1M output tokens
# GPT-4 Turbo: $10 per 1M input tokens, $30 per 1M output tokens
# 
# Claude is 3x cheaper for input, 2x cheaper for output
# Recommendation: Use Claude for most queries, GPT-4 for complex reasoning

# ------------------------------------------
# SETUP STATUS CHECKLIST
# ------------------------------------------
# [ ] Copied this file to .env.local
# [ ] Added OpenAI API key (if using GPT-4)
# [ ] Added Anthropic API key (if using Claude)
# [ ] Set DEMO_MODE=false when ready for production
# [ ] Added billing limits in provider dashboards
# [ ] Tested with demo mode first